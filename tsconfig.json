{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "rootDir": "src",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "paths": {
      "vscode": ["./node_modules/@types/vscode"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out", "test"]
}
